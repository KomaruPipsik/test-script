-- LocalScript (положи в StarterPlayer → StarterPlayerScripts)

local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local hrp = character:WaitForChild("HumanoidRootPart")   -- HumanoidRootPart

local ENABLE_KEY = Enum.KeyCode.Z
local isInfiniteBounce = false
local connection

local BOUNCE_POWER = 10          -- сила отскока вверх (обычный прыжок ~50)
local GROUND_CHECK_DISTANCE = 2  -- за сколько studs до пола отталкиваться

local function tryBounce()
    if humanoid.Health <= 0 then return end
    if hrp.Velocity.Y > -10 then return end   -- не отталкиваем если ещё летим вверх или почти не падаем

    local ray = Ray.new(hrp.Position, Vector3.new(0, -500, 0))
    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {character}
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude

    local result = workspace:Raycast(ray.Origin, ray.Direction, raycastParams)

    if result then
        local distance = (hrp.Position - result.Position).Y
        if distance <= GROUND_CHECK_DISTANCE then
            -- отталкиваемся
            hrp.Velocity = Vector3.new(
                hrp.Velocity.X * 0.3,
                BOUNCE_POWER,
                hrp.Velocity.Z * 0.3
            )
        end
    end
end

local function onInputBegan(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode ~= ENABLE_KEY then return end

    isInfiniteBounce = not isInfiniteBounce

    if isInfiniteBounce then
        game:GetService("StarterGui"):SetCore("ChatMakeSystemMessage", {
            Text = "[Infinite Bounce] → ВКЛЮЧЕНО",
            Color = Color3.fromRGB(50, 255, 100),
            Font = Enum.Font.SourceSansBold
        })

        if connection then connection:Disconnect() end
        connection = RunService.Heartbeat:Connect(tryBounce)
    else
        game:GetService("StarterGui"):SetCore("ChatMakeSystemMessage", {
            Text = "[Infinite Bounce] → ВЫКЛЮЧЕНО",
            Color = Color3.fromRGB(255, 80, 80),
            Font = Enum.Font.SourceSansBold
        })

        if connection then
            connection:Disconnect()
            connection = nil
        end
    end
end

UserInputService.InputBegan:Connect(onInputBegan)

-- на респаун персонажа
player.CharacterAdded:Connect(function(newChar)
    character = newChar
    humanoid = newChar:WaitForChild("Humanoid")
    hrp = newChar:WaitForChild("HumanoidRootPart")

    -- если режим был включён — сразу подключаем снова
    if isInfiniteBounce then
        if connection then connection:Disconnect() end
        connection = RunService.Heartbeat:Connect(tryBounce)
    end
end)
