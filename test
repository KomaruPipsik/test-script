local Player = game.Players.LocalPlayer
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

local active = false

local function getCharacterData()
	local char = Player.Character
	if char then
		local hum = char:FindFirstChildOfClass("Humanoid")
		local root = char:FindFirstChild("HumanoidRootPart")
		return char, hum, root
	end
	return nil, nil, nil
end

UserInputService.InputBegan:Connect(function(input, processed)
	if processed then return end
	
	if input.KeyCode == Enum.KeyCode.Z then
		active = not active
		
		game:GetService("StarterGui"):SetCore("SendNotification", {
			Title = "Evade BHOP";
			Text = active and "РЕЖИМ: ВКЛ" or "РЕЖИМ: ВЫКЛ";
			Duration = 1;
		})
	end
end)

RunService.Heartbeat:Connect(function()
	if not active then return end
	
	local char, hum, root = getCharacterData()
	
	if char and hum and root and hum.Health > 0 then
		-- Проверяем, что персонаж падает или находится очень низко (скорость Y < 1)
		if root.AssemblyLinearVelocity.Y < 1 then
			
			local params = RaycastParams.new()
			params.FilterDescendantsInstances = {char}
			params.FilterType = Enum.RaycastFilterType.Exclude
			
			-- ДИСТАНЦИЯ: 3.1 — это почти вплотную к полу для стандартного персонажа
			-- Если персонаж все еще слишком высоко, попробуй поставить 2.8 или 2.9
			local raycastResult = workspace:Raycast(root.Position, Vector3.new(0, -2, 0), params)
			
			if raycastResult then
				-- Даем импульс вверх. 32-35 — это идеальная высота для быстрого бхопа
				root.AssemblyLinearVelocity = Vector3.new(root.AssemblyLinearVelocity.X, 33, root.AssemblyLinearVelocity.Z)
			end
		end
	end
end)
