local Player = game.Players.LocalPlayer
local UserInputService = game.GetService("UserInputService")
local RunService = game.GetService("RunService")

-- Переменные
local guiCreated = false
local jumpingEnabled = false
local screenGui, mainButton
local lastSavedNickname = "" -- Переменная для хранения ника

-- ФУНКЦИЯ СОЗДАНИЯ КНОПКИ (появится только после нажатия Z)
local function createJumpGui()
	if guiCreated then return end
	
	screenGui = Instance.new("ScreenGui")
	screenGui.Name = "HiddenJumpGui"
	screenGui.Parent = Player:WaitForChild("PlayerGui")

	-- Фрейм для красоты и ввода ника
	local frame = Instance.new("Frame")
	frame.Size = UDim2.new(0, 220, 0, 120)
	frame.Position = UDim2.new(0.5, -110, 0.7, 0)
	frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
	frame.BorderSizePixel = 2
	frame.Parent = screenGui

	-- Поле ввода ника (запоминает значение)
	local nickInput = Instance.new("TextBox")
	nickInput.Size = UDim2.new(0.9, 0, 0, 30)
	nickInput.Position = UDim2.new(0.05, 0, 0.15, 0)
	nickInput.PlaceholderText = "Твой ник здесь..."
	nickInput.Text = lastSavedNickname
	nickInput.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
	nickInput.TextColor3 = Color3.new(1, 1, 1)
	nickInput.Parent = frame

	-- Сама кнопка прыжка
	mainButton = Instance.new("TextButton")
	mainButton.Size = UDim2.new(0.9, 0, 0, 45)
	mainButton.Position = UDim2.new(0.05, 0, 0.5, 0)
	mainButton.Text = "Авто-прыжок: ВЫКЛ"
	mainButton.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
	mainButton.TextColor3 = Color3.new(1, 1, 1)
	mainButton.Font = Enum.Font.SourceSansBold
	mainButton.TextSize = 20
	mainButton.Parent = frame

	-- Логика сохранения ника при изменении
	nickInput.FocusLost:Connect(function()
		lastSavedNickname = nickInput.Text
	end)

	-- Логика переключения прыжка
	mainButton.MouseButton1Click:Connect(function()
		jumpingEnabled = not jumpingEnabled
		if jumpingEnabled then
			mainButton.Text = "Авто-прыжок: ВКЛ"
			mainButton.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
		else
			mainButton.Text = "Авто-прыжок: ВЫКЛ"
			mainButton.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
		end
	end)

	guiCreated = true
end

-- 1. СЛУШАЕМ НАЖАТИЕ КЛАВИШИ Z
UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end -- Игнорируем, если игрок пишет в чат
	
	if input.KeyCode == Enum.KeyCode.Z then
		if not guiCreated then
			createJumpGui() -- Создаем GUI при первом нажатии
		else
			screenGui.Enabled = not screenGui.Enabled -- Скрываем/показываем, если уже создан
		end
	end
end)

-- 2. ЛОГИКА "ОТСКОКА" ОТ ВОЗДУХА
RunService.Heartbeat:Connect(function()
	if not jumpingEnabled then return end
	
	local char = Player.Character
	local root = char and char:FindFirstChild("HumanoidRootPart")
	local hum = char and char:FindFirstChildOfClass("Humanoid")
	
	if root and hum then
		-- Проверяем расстояние до земли (луч вниз на 5.5 единиц)
		local params = RaycastParams.new()
		params.FilterDescendantsInstances = {char}
		params.FilterType = Enum.RaycastFilterType.Exclude
		
		local result = workspace:Raycast(root.Position, Vector3.new(0, -5.5, 0), params)
		
		-- Если результат есть, значит земля близко — прыгаем!
		if result then
			hum.Jump = true
		end
	end
end)
