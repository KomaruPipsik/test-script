local Player = game.Players.LocalPlayer
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

local active = false

local function getCharacterData()
	local char = Player.Character
	if char then
		local hum = char:FindFirstChildOfClass("Humanoid")
		local root = char:FindFirstChild("HumanoidRootPart")
		return char, hum, root
	end
	return nil, nil, nil
end

UserInputService.InputBegan:Connect(function(input, processed)
	if processed then return end
	
	if input.KeyCode == Enum.KeyCode.Z then
		active = not active
		
		game:GetService("StarterGui"):SetCore("SendNotification", {
			Title = "Авто-прыжок";
			Text = active and "НИЗКИЙ РЕЖИМ: ВКЛ" or "ВЫКЛЮЧЕНО";
			Duration = 1.5;
		})
	end
end)

RunService.Heartbeat:Connect(function()
	if not active then return end
	
	local char, hum, root = getCharacterData()
	
	if char and hum and root and hum.Health > 0 then
		local params = RaycastParams.new()
		params.FilterDescendantsInstances = {char}
		params.FilterType = Enum.RaycastFilterType.Exclude
		
		-- Теперь проверяем всего на 3.5 единицы вниз (почти у самых ног)
		local raycastResult = workspace:Raycast(root.Position, Vector3.new(0, 3.5, 0), params)
		
		if raycastResult then
			-- Уменьшили силу прыжка до 35, чтобы отскок был мягким
			root.AssemblyLinearVelocity = Vector3.new(root.AssemblyLinearVelocity.X, 35, root.AssemblyLinearVelocity.Z)
		end
	end
end)
