	local function getCactusFolder()
		local ok, folder = pcall(function()
			return workspace.Game.Map.Parts.ImmovableProps
		end)
		return ok and folder or nil
	end

	-- Состояние хитбоксов
	local cactusHBScale = 2.0   -- множитель размера
	local cactusHBVisible = false
	local cactusBoxes = {}  -- хранит созданные визуальные боксы

	local function applyCactusHitboxes(scale, showBoxes)
		-- Убираем старые визуальные боксы
		for _, b in ipairs(cactusBoxes) do if b and b.Parent then b:Destroy() end end
		cactusBoxes = {}

		local folder = getCactusFolder()
		if not folder then
			notify("ImmovableProps не найден! (Нужна карта Desert Bus)", Color3.fromRGB(200,80,80))
			return
		end
		for _, model in ipairs(folder:GetChildren()) do
			local n = model.Name:lower()
			if n:find("cactus") then
				for _, part in ipairs(model:GetDescendants()) do
					if part:IsA("BasePart") then
						-- Сохраняем оригинальный размер
						if not part:GetAttribute("_APOrigSize") then
							part:SetAttribute("_APOrigSizeX", part.Size.X)
							part:SetAttribute("_APOrigSizeY", part.Size.Y)
							part:SetAttribute("_APOrigSizeZ", part.Size.Z)
						end
						local ox = part:GetAttribute("_APOrigSizeX") or part.Size.X
						local oy = part:GetAttribute("_APOrigSizeY") or part.Size.Y
						local oz = part:GetAttribute("_APOrigSizeZ") or part.Size.Z
						-- Только ширина и длина (X и Z), высота (Y) не меняется
						part.Size = Vector3.new(ox*scale, oy, oz*scale)

						-- Визуальный хитбокс
						if showBoxes then
							local hl = Instance.new("SelectionBox")
							hl.Name = "_CactusHB"
							hl.Adornee = part
							hl.Color3 = Color3.fromRGB(255,50,50)
							hl.LineThickness = 0.06
							hl.SurfaceColor3 = Color3.fromRGB(255,80,80)
							hl.SurfaceTransparency = 0.7
							hl.Parent = part
							table.insert(cactusBoxes, hl)
						else
							for _, c in ipairs(part:GetChildren()) do
								if c.Name == "_CactusHB" then c:Destroy() end
							end
						end
					end
				end
			end
		end
	end

	local function resetCactusHitboxes()
		local folder = getCactusFolder()
		if not folder then return end
		for _, model in ipairs(folder:GetChildren()) do
			if model.Name:lower():find("cactus") then
				for _, part in ipairs(model:GetDescendants()) do
					if part:IsA("BasePart") then
						local ox = part:GetAttribute("_APOrigSizeX")
						local oy = part:GetAttribute("_APOrigSizeY")
						local oz = part:GetAttribute("_APOrigSizeZ")
						if ox then part.Size = Vector3.new(ox, oy, oz) end
						for _, c in ipairs(part:GetChildren()) do
							if c.Name == "_CactusHB" then c:Destroy() end
						end
					end
				end
			end
		end
		cactusBoxes = {}
