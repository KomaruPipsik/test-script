	end
	local function removeFarmPlatform()
		if _farmPlatform and _farmPlatform.Parent then _farmPlatform:Destroy() end
		_farmPlatform = nil
	end

	-- Возвращает Visual-модельки из Effects/Tickets
	local function getTickets()
		local tickets = {}
		local ok, folder = pcall(function()
			return workspace.Effects.Tickets
		end)
		if not ok or not folder then return tickets end
		for _, child in ipairs(folder:GetChildren()) do
			if child:IsA("Model") and child.Name == "Visual" then
				table.insert(tickets, child)
			end
		end
		return tickets
	end

	-- Возвращает позицию модельки (PrimaryPart или первый BasePart)
	local function getModelPos(model)
		if model.PrimaryPart then return model.PrimaryPart.Position end
		local p = model:FindFirstChildWhichIsA("BasePart")
		return p and p.Position or nil
	end

	makeToggle(f, "Авто-фарм тикетов", "Телепортирует к Visual в Effects/Tickets автоматически",
		function(on)
			State.AutoFarm = on
			if not on then
				removeFarmPlatform()
				notify("Авто-фарм: ВЫКЛ")
			else
				notify("Авто-фарм: ВКЛ — ищу тикеты...", Color3.fromRGB(255, 215, 50))
				task.spawn(function()
					while State.AutoFarm do
						local char = getChar()
						local root = char and char:FindFirstChild("HumanoidRootPart")
						if root then
							local tickets = getTickets()
							if #tickets > 0 then
								-- Берём ближайший тикет
								local best, bestDist = nil, math.huge
								for _, t in ipairs(tickets) do
									local pos = getModelPos(t)
									if pos then
										local d = (pos - root.Position).Magnitude
										if d < bestDist then bestDist = d; best = t end
									end
								end
								if best then
									local tPos = getModelPos(best)
									if tPos then
										-- Телепорт на 500 блоков выше тикета
										local safePos = tPos + Vector3.new(0, 500, 0)
										root.CFrame = CFrame.new(safePos)
										-- Создаём платформу под игроком
										task.wait(0.05)
										ensureFarmPlatform()
										notify("Тикет найден! Жди...", Color3.fromRGB(255, 215, 50))
										-- Ждём пока тикет не исчезнет (подобрали) или таймаут
										local waited = 0
										while best and best.Parent and waited < 8 do
											task.wait(0.2); waited = waited + 0.2
										end
										-- Телепорт обратно на тикет (теперь его нет — стоим в воздухе)
										if not best.Parent then
											notify("Тикет собран! ✓", Color3.fromRGB(80, 220, 100))
										end
									end
								else
									-- Тикетов нет — ждём
									removeFarmPlatform()
									task.wait(1)
								end
							else
								removeFarmPlatform()
								task.wait(1)
							end
						else
							task.wait(0.5)
						end
					end
					removeFarmPlatform()
				end)
			end
		end, 33, "AutoFarm")

