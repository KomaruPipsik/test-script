local function getFovZoom()
	if _fovZoom and _fovZoom.Parent then return _fovZoom end
	local scripts = Player:FindFirstChild("PlayerScripts")
	if scripts then
		local cam = scripts:FindFirstChild("Camera")
		if cam then
			local fovAdj = cam:FindFirstChild("FOVAdjusters")
			if fovAdj then _fovZoom = fovAdj:FindFirstChild("Zoom") end
		end
	end
	return _fovZoom
end

local _origFOV = nil

RunService.RenderStepped:Connect(function()
	local cam = workspace.CurrentCamera
	if not cam then return end
	if State.FOVChanged then
		if not _origFOV then _origFOV = cam.FieldOfView end
		cam.FieldOfView = CONFIG.FOV
		local zoom = getFovZoom()
		if zoom then zoom.Value = math.clamp(CONFIG.FOV / 70, 0.1, 5) end
	else
		if _origFOV then
			cam.FieldOfView = _origFOV
			_origFOV = nil
		end
		local zoom = getFovZoom()
		if zoom then zoom.Value = 1 end
	end
end)

