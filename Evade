-- ══════════════════════════════════════════
--  LAG SWITCH — логика рывка
-- ══════════════════════════════════════════
local function doLagSwitch()
	if not State.LagSwitchOn then return end
	local char = getChar(); if not char then return end
	local root = char:FindFirstChild("HumanoidRootPart")
	local hum  = char and char:FindFirstChildWhichIsA("Humanoid")
	if not root or not hum then return end

	-- Проверяем угол наклона поверхности под ногами
	local rp = RaycastParams.new()
	rp.FilterType = Enum.RaycastFilterType.Exclude
	rp.FilterDescendantsInstances = {char}
	local hit = workspace:Raycast(root.Position, Vector3.new(0, -6, 0), rp)

	if hit then
		local angle = math.deg(math.acos(math.clamp(hit.Normal:Dot(Vector3.new(0,1,0)),-1,1)))
		-- Не применяем рывок на почти вертикальных поверхностях (>89°)
		if angle > 89 then return end
	end

	-- Направление движения (по look vector персонажа)
	local lookDir = root.CFrame.LookVector
	local vel = root.AssemblyLinearVelocity
	-- Если персонаж движется — используем направление скорости, иначе — look
	local dir
	if vel.Magnitude > 1 then
		dir = Vector3.new(vel.X, 0, vel.Z).Unit
	else
		dir = Vector3.new(lookDir.X, 0, lookDir.Z).Unit
	end

	-- Рандомный рывок с небольшим отклонением
	local randAngle = math.rad(math.random(-25, 25))
	local cos, sin = math.cos(randAngle), math.sin(randAngle)
	local dashDir = Vector3.new(
		dir.X * cos - dir.Z * sin,
		0,
		dir.X * sin + dir.Z * cos
	).Unit

	local force = CONFIG.LagSwitchForce + math.random(-10, 10)

	-- Если на наклонной поверхности — добавляем вертикальную компоненту
	local verticalBoost = 0
	if hit then
		local angle = math.deg(math.acos(math.clamp(hit.Normal:Dot(Vector3.new(0,1,0)),-1,1)))
		if angle >= 5 and angle <= 89 then
			verticalBoost = force * math.sin(math.rad(angle)) * 0.5
		end
	end

	root.AssemblyLinearVelocity = Vector3.new(
		dashDir.X * force,
		math.max(root.AssemblyLinearVelocity.Y, verticalBoost),
		dashDir.Z * force
	)
	hum:ChangeState(Enum.HumanoidStateType.Jumping)
end

