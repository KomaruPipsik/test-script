	track.Size = UDim2.new(1, -20, 0, 6); track.Position = UDim2.new(0, 10, 0, 32)
	track.BackgroundColor3 = Color3.fromRGB(30, 32, 50); track.BorderSizePixel = 0; track.Parent = row
	Instance.new("UICorner").Parent = track

	local fill = Instance.new("Frame")
	fill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
	fill.BackgroundColor3 = THEME.accent; fill.BorderSizePixel = 0; fill.Parent = track
	Instance.new("UICorner").Parent = fill

	local thumb = Instance.new("Frame")
	thumb.Size = UDim2.new(0, 14, 0, 14)
	thumb.Position = UDim2.new((default - min) / (max - min), -7, 0.5, -7)
	thumb.BackgroundColor3 = Color3.fromRGB(220, 225, 255); thumb.BorderSizePixel = 0
	thumb.ZIndex = 3; thumb.Parent = track; Instance.new("UICorner").Parent = thumb

	local slBtn = Instance.new("TextButton")
	slBtn.Size = UDim2.new(1, 0, 1, 8); slBtn.Position = UDim2.new(0, 0, 0, -4)
	slBtn.BackgroundTransparency = 1; slBtn.Text = ""; slBtn.ZIndex = 4; slBtn.Parent = track

	local dragging = false
	local function updateSlider(x)
		local rel = math.clamp((x - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
		local val = math.floor(min + rel * (max - min))
		fill.Size = UDim2.new(rel, 0, 1, 0)
		thumb.Position = UDim2.new(rel, -7, 0.5, -7)
		valLbl.Text = tostring(val) .. suffix
		callback(val)
	end
	slBtn.MouseButton1Down:Connect(function() dragging = true end)
	UserInputService.InputChanged:Connect(function(inp)
		if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
			updateSlider(inp.Position.X)
		end
	end)
	UserInputService.InputEnded:Connect(function(inp)
		if inp.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
	end)
	slBtn.MouseButton1Click:Connect(function()
		updateSlider(UserInputService:GetMouseLocation().X)
	end)
end

