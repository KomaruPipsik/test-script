local ADMINS = {"Matik202022", "YuraSiYuraSi", "useugks8_Tvink"}

local Licenses = {
	Matik202022    = {permanent = true},
	YuraSiYuraSi   = {permanent = true},
	useugks8_Tvink = {permanent = true},
}

local function isAdmin(name)
	for _, a in ipairs(ADMINS) do if a == name then return true end end
	return false
end
local function getLicense(name) return Licenses[name] end
local function isLicensed(name)
	local lic = getLicense(name)
	if not lic then return false end
	if lic.permanent then return true end
	return os.time() < lic.expiry
end
local function getTimeLeft(name)
	local lic = getLicense(name)
	if not lic then return nil end
	if lic.permanent then return "Навсегда🤑" end
	local secs = math.max(0, lic.expiry - os.time())
	if secs == 0 then return "Истекло" end
	local mins  = math.floor(secs / 60)
	local hours = math.floor(mins / 60)
	local days  = math.floor(hours / 24)
	local weeks = math.floor(days / 7)
	local months= math.floor(days / 30)
	if months >= 1 then return months.." мес. "..(days%30).." дн."
	elseif weeks >= 1 then return weeks.." нед. "..(days%7).." дн."
	elseif days  >= 1 then return days.." дн. "..(hours%24).." ч."
	elseif hours >= 1 then return hours.." ч. "..(mins%60).." мин."
	else return mins.." мин." end
end
local function addLicense(username, seconds)
	if seconds then Licenses[username] = {expiry = os.time()+seconds}
	else Licenses[username] = {permanent = true} end
end
local function removeLicense(username) Licenses[username] = nil end

