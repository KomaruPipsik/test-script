RunService.Heartbeat:Connect(function(dt)
	local char = getChar(); if not char then return end
	local hum  = char:FindFirstChild("Humanoid")
	local root = char:FindFirstChild("HumanoidRootPart")
	if not hum or not root then return end

	-- Запись
	if State.Recording then
		table.insert(RecordedFrames, {CFrame = root.CFrame, dt = dt})
	end

	-- Авто-прыжок от пола (срабатывает когда почти касаешься земли — в воздухе ИЛИ на полу)
	if State.AutoJump then
		_rayParamsChar.FilterDescendantsInstances = {char}
		local ray = workspace:Raycast(root.Position, Vector3.new(0, -CONFIG.AutoJumpThreshold, 0), _rayParamsChar)
		if ray then
			hum:ChangeState(Enum.HumanoidStateType.Jumping)
			root.AssemblyLinearVelocity = Vector3.new(
				root.AssemblyLinearVelocity.X, CONFIG.AutoJumpHeight, root.AssemblyLinearVelocity.Z)
		end
	end

	-- Slope Bounce
	if State.SlopeBounce then
		_rayParamsChar.FilterDescendantsInstances = {char}
		local vel = root.AssemblyLinearVelocity
		local checkDist = CONFIG.SlopeBounceCheckDist
		local hit = workspace:Raycast(root.Position, Vector3.new(vel.X*0.1,-checkDist,vel.Z*0.1), _rayParamsChar)
			or workspace:Raycast(root.Position, Vector3.new(0,-checkDist,0), _rayParamsChar)
		if hit then
			local normal = hit.Normal
			local angle = math.deg(math.acos(math.clamp(normal:Dot(Vector3.new(0,1,0)),-1,1)))
			if angle >= CONFIG.SlopeMinAngle and angle <= CONFIG.SlopeMaxAngle then
				local dist = (root.Position - hit.Position).Magnitude
				if dist <= checkDist * 0.65 then
					local force = CONFIG.SlopeRandEnabled
						and math.random(CONFIG.SlopeRandMin, CONFIG.SlopeRandMax)
						or  CONFIG.SlopeBounceForce
					local bounceDir = (normal + Vector3.new(0,1,0)).Unit
					root.AssemblyLinearVelocity = Vector3.new(
						bounceDir.X*force*0.4, force, bounceDir.Z*force*0.4)
					hum:ChangeState(Enum.HumanoidStateType.Jumping)
				end
			end
		end
	end

	-- Bunny Hop
	if State.BunnyHop and hum.FloorMaterial ~= Enum.Material.Air then
		hum:ChangeState(Enum.HumanoidStateType.Jumping)
	end

	-- Spinbot (накапливаем угол — нет дёрганья)
	if State.Spinbot then
		spinAngle = (spinAngle + CONFIG.SpinSpeed) % 360
		root.CFrame = CFrame.new(root.Position)
			* CFrame.Angles(0, math.rad(spinAngle), 0)
	end

	-- Fake Lag
	if State.FakeLag then
		fakeLagTimer = fakeLagTimer + dt
		if fakeLagTimer >= 0.18 then
			fakeLagTimer = 0
			local savedVel = root.AssemblyLinearVelocity
			local savedCF  = root.CFrame
			root.CFrame = savedCF * CFrame.new(0,0,5)
			root.AssemblyLinearVelocity = Vector3.new(0,0,0)
			task.defer(function()
				local c2 = getChar()
				local r2 = c2 and c2:FindFirstChild("HumanoidRootPart")
				if r2 and State.FakeLag then r2.CFrame=savedCF; r2.AssemblyLinearVelocity=savedVel end
			end)
		end
	end

	-- Rainbow Trail
	if State.RainbowTrail then
		if not trail or not trail.Parent then createTrail() end
		rainbowHue = (rainbowHue + dt*0.35) % 1
		if trail then
			trail.Color = ColorSequence.new{
				ColorSequenceKeypoint.new(0, Color3.fromHSV(rainbowHue,1,1)),
				ColorSequenceKeypoint.new(1, Color3.fromHSV((rainbowHue+0.5)%1,1,1))
			}
		end
	else
		if trail and trail.Parent then trail:Destroy(); trail=nil end
	end
end)

-- ── Lag Switch (логика из script2 by Pixie) ──
local _lagSwitchActive = false

local function doLagSwitch()
	if _lagSwitchActive then return end
	local char = getChar(); if not char then return end
	local root = char:FindFirstChild("HumanoidRootPart")
	local hum  = char:FindFirstChild("Humanoid")
	if not root or not hum then return end

	-- Направление движения
	local direction = root.CFrame.LookVector
	local speed = root.AssemblyLinearVelocity.Magnitude
	if speed < 1 then speed = 20 end

	-- Проверяем угол поверхности (не работаем на >89°)
	local rp = RaycastParams.new()
	rp.FilterType = Enum.RaycastFilterType.Exclude
	rp.FilterDescendantsInstances = {char}
	local hit = workspace:Raycast(root.Position, Vector3.new(0, -6, 0), rp)
	if hit then
		local surfAngle = math.deg(math.acos(math.clamp(
			hit.Normal:Dot(Vector3.new(0,1,0)), -1, 1)))
		if surfAngle > 89 then return end
	end

	_lagSwitchActive = true

	-- 1. Анти-гравитация через VectorForce
	local attachment = Instance.new("Attachment", root)
	local vf = Instance.new("VectorForce", root)
	vf.Attachment0 = attachment
	pcall(function()
		vf.Force = Vector3.new(0, workspace.Gravity * root:GetMass(), 0)
	end)

	-- 2. Заморозка на lagDuration
	root.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
	root.Anchored = true

	local lagDuration = CONFIG.LagSwitchForce / 60  -- 0.5–2.0 сек в зависимости от силы
	lagDuration = math.clamp(lagDuration, 0.3, 2.0)
	task.wait(lagDuration)

	-- 3. Телепорт вперёд + вверх
	local targetPos = root.Position + (direction * 10) + Vector3.new(0, 20, 0)
	root.CFrame = CFrame.new(targetPos, targetPos + direction)

	root.Anchored = false

	-- 4. Импульс
	local boost = math.clamp(speed / 50, 1.0, 3.0)
	root.AssemblyLinearVelocity = (direction * (100 * boost)) + Vector3.new(0, 60, 0)
	hum:ChangeState(Enum.HumanoidStateType.Jumping)

	-- 5. Убираем анти-гравитацию через 2 сек
	task.delay(2, function()
		pcall(function() vf:Destroy(); attachment:Destroy() end)
		_lagSwitchActive = false
	end)
end

