local fpsHistory = {}
local FPS_SHOWN = false
RunService.Heartbeat:Connect(function(dt)
	if not FPS_SHOWN then return end
	table.insert(fpsHistory, 1 / math.max(dt, 0.001))
	if #fpsHistory > 20 then table.remove(fpsHistory, 1) end
	local sum = 0
	for _, v in ipairs(fpsHistory) do sum = sum + v end
	local fps = math.floor(sum / #fpsHistory)
	fpsLbl.Text = tostring(fps)
	local c
	if fps >= 60 then
		c = Color3.fromRGB(60, 210, 120)    -- зелёный
	elseif fps >= 30 then
		c = Color3.fromRGB(230, 195, 50)    -- жёлтый
	elseif fps >= 10 then
		c = Color3.fromRGB(230, 130, 50)    -- оранжевый
	else
		c = Color3.fromRGB(210, 60, 60)     -- красный
	end
	fpsLbl.TextColor3 = c
	fpsColorLine.BackgroundColor3 = c
end)

