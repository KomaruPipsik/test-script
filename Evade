local function createTrail()
	local char = getChar(); if not char then return end
	-- ИСПРАВЛЕНО: безопасный поиск
	local root = char:FindFirstChild("HumanoidRootPart")
	local head = char:FindFirstChild("Head")
	if not root or not head then return end
	local a0 = Instance.new("Attachment"); a0.Parent = root
	local a1 = Instance.new("Attachment"); a1.Parent = head
	trail = Instance.new("Trail")
	trail.Attachment0 = a0; trail.Attachment1 = a1
	trail.Lifetime = 1.5; trail.MinLength = 0
	trail.WidthScale = NumberSequence.new(1, 0)
	trail.Parent = root
end

local _rayParamsChar = RaycastParams.new()
_rayParamsChar.FilterType = Enum.RaycastFilterType.Exclude

