		for _, p in ipairs(Players:GetPlayers()) do
			if p ~= Player and p.Character then
				local pc = p.Character
				-- ИСПРАВЛЕНО: ищем Humanoid через FindFirstChildWhichIsA
				local ph = pc:FindFirstChildWhichIsA("Humanoid")
				if ph and not pc:FindFirstChild("_PlayerHL") then
					local hl = Instance.new("Highlight")
					hl.Name = "_PlayerHL"; hl.FillColor = Color3.fromRGB(50,120,255)
					hl.OutlineColor = Color3.fromRGB(70,160,255); hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
					hl.Parent = pc
				end
			end
		end
	end

	-- NPC / Bot ESP — ИСПРАВЛЕНО: FindFirstChildWhichIsA
	if State.BotESP then
		for _, obj in ipairs(workspace:GetDescendants()) do
			if obj:IsA("Model") then
				local bh = obj:FindFirstChildWhichIsA("Humanoid")
				if bh and not Players:GetPlayerFromCharacter(obj)
					and not obj:FindFirstChild("_BotHL") then
					local hl = Instance.new("Highlight")
					hl.Name = "_BotHL"; hl.FillColor = Color3.fromRGB(200,50,50)
					hl.OutlineColor = Color3.fromRGB(255,80,80)
					hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop; hl.Parent = obj
				end
			end
		end
	end

	-- Distance ESP — ИСПРАВЛЕНО: безопасный HumanoidRootPart
	if State.DistanceESP then
		for _, p in ipairs(Players:GetPlayers()) do
			if p ~= Player and p.Character then
				local pr = p.Character:FindFirstChild("HumanoidRootPart")
				if pr then
					local bg = pr:FindFirstChild("_DistBG")
					if not bg then
						bg = Instance.new("BillboardGui")
						bg.Name = "_DistBG"; bg.Size = UDim2.new(0,60,0,20)
						bg.AlwaysOnTop = true; bg.Parent = pr
						local distLbl = Instance.new("TextLabel")
						distLbl.Name = "_DistLbl"; distLbl.Size = UDim2.new(1,0,1,0)
						distLbl.BackgroundTransparency = 1; distLbl.TextColor3 = Color3.fromRGB(255,255,255)
						distLbl.TextSize = 12; distLbl.Font = Enum.Font.SourceSansBold; distLbl.Parent = bg
					end
					local dl = bg:FindFirstChild("_DistLbl")
					if dl then
						local dist = math.floor((pr.Position - root.Position).Magnitude)
						dl.Text = dist .. "м"
					end
				end
			end
		end
	end

	-- Auto Jump
	if State.AutoJump then
		_rayParamsChar.FilterDescendantsInstances = {char}
		local hit = workspace:Raycast(root.Position, Vector3.new(0, -CONFIG.AutoJumpThreshold, 0), _rayParamsChar)
		if hit and hum.FloorMaterial ~= Enum.Material.Air then
			root.AssemblyLinearVelocity = Vector3.new(
				root.AssemblyLinearVelocity.X,
				math.max(root.AssemblyLinearVelocity.Y, CONFIG.AutoJumpHeight),
				root.AssemblyLinearVelocity.Z)
			hum:ChangeState(Enum.HumanoidStateType.Jumping)
		end
	end

	-- Slope Bounce
	if State.SlopeBounce then
		_rayParamsChar.FilterDescendantsInstances = {char}
		local vel = root.AssemblyLinearVelocity
		local checkDist = CONFIG.SlopeBounceCheckDist
		local hit = workspace:Raycast(root.Position, Vector3.new(vel.X*0.1,-checkDist,vel.Z*0.1), _rayParamsChar)
			or workspace:Raycast(root.Position, Vector3.new(0,-checkDist,0), _rayParamsChar)
		if hit then
			local normal = hit.Normal
			local angle = math.deg(math.acos(math.clamp(normal:Dot(Vector3.new(0,1,0)),-1,1)))
			if angle >= CONFIG.SlopeMinAngle and angle <= CONFIG.SlopeMaxAngle then
				local dist = (root.Position - hit.Position).Magnitude
				if dist <= checkDist * 0.65 then
					local force = CONFIG.SlopeRandEnabled
						and math.random(CONFIG.SlopeRandMin, CONFIG.SlopeRandMax)
						or CONFIG.SlopeBounceForce
					local bounceDir = (normal + Vector3.new(0,1,0)).Unit
					root.AssemblyLinearVelocity = Vector3.new(
						bounceDir.X*force*0.4, force, bounceDir.Z*force*0.4)
					hum:ChangeState(Enum.HumanoidStateType.Jumping)
				end
			end
		end
	end

	-- Bunny Hop
	if State.BunnyHop and hum.FloorMaterial ~= Enum.Material.Air then
		hum:ChangeState(Enum.HumanoidStateType.Jumping)
	end

	-- Spinbot (логика сохранена, интерфейс убран)
	if State.Spinbot then
		spinAngle = (spinAngle + CONFIG.SpinSpeed) % 360
		root.CFrame = CFrame.new(root.Position) * CFrame.Angles(0, math.rad(spinAngle), 0)
	end

	-- Fake Lag (логика сохранена, интерфейс убран)
	if State.FakeLag then
		fakeLagTimer = fakeLagTimer + dt
		if fakeLagTimer >= 0.18 then
			fakeLagTimer = 0
			local savedVel = root.AssemblyLinearVelocity
			local savedCF  = root.CFrame
			root.CFrame = savedCF * CFrame.new(0,0,5)
			root.AssemblyLinearVelocity = Vector3.new(0,0,0)
			task.defer(function()
				local c2 = getChar()
				local r2 = c2 and c2:FindFirstChild("HumanoidRootPart")
				if r2 and State.FakeLag then r2.CFrame=savedCF; r2.AssemblyLinearVelocity=savedVel end
			end)
		end
	end

	-- Rainbow Trail
	if State.RainbowTrail then
		if not trail or not trail.Parent then createTrail() end
		rainbowHue = (rainbowHue + dt*0.35) % 1
		if trail then
			trail.Color = ColorSequence.new{
				ColorSequenceKeypoint.new(0, Color3.fromHSV(rainbowHue,1,1)),
				ColorSequenceKeypoint.new(1, Color3.fromHSV((rainbowHue+0.5)%1,1,1))
			}
		end
	else
		if trail and trail.Parent then trail:Destroy(); trail=nil end
	end
end)

